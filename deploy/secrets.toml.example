# Plantilla de credenciales de la API de Whoop.
# Copia este archivo a  .streamlit/secrets.toml  (que está FUERA de git) y rellena
# con los datos de tu app del portal de desarrollador de Whoop (developer.whoop.com).
#
#   En tu PC:   Tracker\.streamlit\secrets.toml
#   En la VPS:  /opt/senal/.streamlit/secrets.toml   (créalo una vez por SSH)
#
# La redirect_uri debe coincidir EXACTAMENTE con la registrada en la app de Whoop.

[whoop]
client_id = "TU_CLIENT_ID"
client_secret = "TU_CLIENT_SECRET"
redirect_uri = "https://dailytracker.cloud"
