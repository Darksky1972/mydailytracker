# Bloque para el endpoint MCP de Claude. PÉGALO DENTRO del server { ... } que
# escucha en 443 (el de HTTPS que creó certbot), junto al location / que ya existe.
# Cambia PON_AQUI_TU_TOKEN_SECRETO por el token que generes (ver deploy/MCP.md).
#
# Va protegido por un token propio (cabecera Authorization), SIN la contraseña del
# sitio, para que Claude pueda conectarse con ese token.
location /mcp {
    auth_basic off;
    if ($http_authorization != "Bearer PON_AQUI_TU_TOKEN_SECRETO") { return 401; }

    proxy_pass http://127.0.0.1:8765;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection "";

    # MCP usa streaming (SSE): sin buffering y con timeouts largos.
    proxy_buffering off;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
}
